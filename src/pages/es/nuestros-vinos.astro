---
import BaseLayout from '../../layouts/BaseLayout.astro';

const wines = [
  { name: 'Jaume Clarella', image: '/images/wines/Jaume.webp' },
  { name: 'Francina Clarella', image: '/images/wines/Francisca.webp' },
  { name: 'Teresa Clarella', image: '/images/wines/Teresa.webp' },
  { name: 'Albinia Clarella', image: '/images/wines/Albinia.webp' },
  { name: 'Pinot Noir Clarella', image: '/images/wines/Clarella-slider-vins-1.webp' },
  { name: 'Riesling Clarella', image: '/images/wines/Clarella-slider-vins-2.webp' },
  { name: 'Clarella Vi Negre', image: '/images/wines/Clarella-slider-vins-3.webp' },
  { name: 'Clarella Rosat Fresc', image: '/images/wines/Clarella-slider-vins-4.webp' },
];
---

<BaseLayout title="NUESTROS VINOS - Clarella" description="Clarella produce nueve referencias de vinos de montaña en el pre-Pirineo Catalán" lang="es">
  <!-- Hero Banner -->
  <section class="page-hero">
    <div class="page-hero-bg">
      <img src="/images/wines/Clarella-slider-vins-1.webp" alt="Vinos de Clarella" class="page-hero-img" />
      <div class="page-hero-overlay"></div>
    </div>
    <div class="page-hero-content">
      <h1 class="page-hero-title text-uppercase">Nuestros Vinos</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section section--cream">
    <div class="container container--narrow text-center">
      <div class="reveal">
        <p class="vins-intro">
          Clarella produce actualmente nueve referencias de vinos de montaña. Trabajamos en seis campos que se encuentran entre 880 y 1.000 metros de altitud. Las uvas que cultivamos son tempranillo, macabeo, riesling y pinot noir. La tierra es una mezcla de arcillas, calizas y roca de pizarra, lo que les otorga una maravillosa expresión de mineralidad.
        </p>
        <p class="vins-intro">
          Vinos de montaña, monovarietales, barricas de roble, cuidado y tiempo. Les presentamos los vinos de Clarella.
        </p>
      </div>
    </div>
  </section>

  <!-- Wine Grid -->
  <section class="section">
    <div class="container">
      <div class="wines-grid">
        {wines.map((wine, i) => (
          <div class="wine-card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <div class="wine-card-image">
              <img src={wine.image} alt={wine.name} loading="lazy" />
            </div>
            <h3 class="wine-card-name">{wine.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .page-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .page-hero-title {
    color: var(--color-text-light);
    font-size: var(--text-6xl);
    letter-spacing: 0.1em;
  }

  .vins-intro {
    font-size: var(--text-lg);
    line-height: 1.8;
  }

  .wines-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2xl);
  }

  .wine-card {
    text-align: center;
    transition: transform var(--transition-base);
  }

  .wine-card:hover {
    transform: translateY(-8px);
  }

  .wine-card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 2px;
    margin-bottom: var(--space-md);
    background: var(--color-bg-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
  }

  .wine-card-image img {
    max-height: 100%;
    width: auto;
    object-fit: contain;
    transition: transform var(--transition-slow);
  }

  .wine-card:hover .wine-card-image img {
    transform: scale(1.05);
  }

  .wine-card-name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-text-dark);
    letter-spacing: 0.05em;
  }

  @media (max-width: 1024px) {
    .wines-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .wines-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }

    .page-hero-title {
      font-size: var(--text-4xl);
    }
  }

  @media (max-width: 480px) {
    .wines-grid {
      grid-template-columns: 1fr;
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>
