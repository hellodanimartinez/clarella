---
import BaseLayout from '../../layouts/BaseLayout.astro';

const FAREHARBOR_URL = 'https://fareharbor.com/embeds/book/clarellawines/?from-ssl=yes&ga=UA-206284799-1%2C267788612.1712174212%3B&ga4t=&g4=yes&cp=no&csp=no&back=https%3A%2F%2Fclarellawines.com%2Fes%2Fwine-tasting%2F&language=es-es&u=46a34fa2-7424-45ec-afbf-2d966a78f39e';
---

<BaseLayout title="VISITS AND PAIRINGS - Clarella" description="Guided tours of the farmhouse with wine tasting and pairing. Origins and Essential experiences." lang="en">
  <!-- Hero Banner -->
  <section class="page-hero">
    <div class="page-hero-bg">
      <img src="/images/events/Clarella_unica-esdeveniments-copia.webp" alt="Events at Clarella" class="page-hero-img" />
      <div class="page-hero-overlay"></div>
    </div>
    <div class="page-hero-content">
      <h1 class="page-hero-title text-uppercase">Visits & Pairings</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section section--cream">
    <div class="container container--narrow text-center">
      <div class="reveal">
        <p class="events-intro">
          Mas Clarella is open to lovers of wine, history, and beauty. On weekends, we offer guided tours of the farmhouse, featuring wine tastings and pairings. You will discover the history of this extraordinary corner in the north of the Osona region and enjoy its wines, paired with local products. White and red wines, cheeses, cured meats, and hams that will awaken your senses.
        </p>
        <h3 class="events-cta-title" style="margin-top: var(--space-xl);">PLAN YOUR EXPERIENCE AT CLARELLA</h3>
      </div>
    </div>
  </section>

  <!-- Experiences -->
  <section class="section">
    <div class="container">
      <div class="experiences-grid">
        <!-- ORÍGENS -->
        <div class="experience-card reveal">
          <div class="experience-header">
            <h2 class="experience-name">ORIGINS</h2>
          </div>
          <div class="experience-body">
            <ul class="experience-features">
              <li>Guided tour of our mountain vineyards, where we explain how we work the vines at altitude, the challenges involved, and how this influences the wine's quality and personality.</li>
              <li>Guided tour of Mas Clarella, a farmhouse with centuries of history, where you'll discover the estate's architectural heritage and the Clarella family history.</li>
              <li>Pairing tasting with <strong>3 young wines + 2 reserve or Premium wines</strong> (depending on the season), accompanied by a board of artisan cheeses, cured meats, and coca bread.</li>
            </ul>
            <div class="experience-pricing">
              <p class="price"><span class="price-label">Adults +18:</span> <span class="price-value">39.00€</span></p>
              <p class="price"><span class="price-label">Ages 6 to 18:</span> <span class="price-value">12.00€</span></p>
            </div>
            <a href={FAREHARBOR_URL} target="_blank" rel="noopener noreferrer" class="btn btn--gold experience-btn">
              BOOK NOW
            </a>
          </div>
        </div>

        <!-- ESSENCIAL -->
        <div class="experience-card reveal" style="transition-delay: 0.15s;">
          <div class="experience-header">
            <h2 class="experience-name">ESSENTIAL</h2>
          </div>
          <div class="experience-body">
            <ul class="experience-features">
              <li>Guided tour of our mountain vineyards, where we explain how we work the vines at altitude, the challenges involved, and how this influences the wine's quality and personality.</li>
              <li>Guided tour of Mas Clarella, a farmhouse with centuries of history, where you'll discover the estate's architectural heritage and the Clarella family history.</li>
              <li>Tasting of <strong>three young wines</strong> from the cellar, paired with a snack of local products like artisan fuet and cheese, rounding off the experience with the flavors of our land.</li>
            </ul>
            <div class="experience-pricing">
              <p class="price"><span class="price-label">Adults +18:</span> <span class="price-value">25.00€</span></p>
              <p class="price"><span class="price-label">Ages 6 to 18:</span> <span class="price-value">12.00€</span></p>
            </div>
            <a href={FAREHARBOR_URL} target="_blank" rel="noopener noreferrer" class="btn btn--gold experience-btn">
              BOOK NOW
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="section section--cream">
    <div class="container">
      <div class="info-grid reveal">
        <div class="info-item">
          <h4 class="info-label">DURATION</h4>
          <p>2 Hours</p>
        </div>
        <div class="info-item">
          <h4 class="info-label">LANGUAGE</h4>
          <p>Catalan, Spanish.<br/><strong>*English, *French.</strong><br/>(*book via email: <a href="mailto:info@clarella.cat">info@clarella.cat</a>)</p>
        </div>
        <div class="info-item">
          <h4 class="info-label">ACCESSIBILITY</h4>
          <p>All activities are wheelchair accessible except the main house tour</p>
        </div>
        <div class="info-item">
          <h4 class="info-label">CONFIRM YOUR BOOKING</h4>
          <p><a href="tel:+34683602397">+34 683 602 397</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="section section--dark">
    <div class="container container--narrow text-center">
      <div class="reveal">
        <h2 class="section-title text-uppercase">How to Get Here</h2>
        <p style="margin-bottom: var(--space-lg);">Click on the map to open Google Maps</p>
        <div class="map-container">
          <a href="https://www.google.com/maps/place/Mas+Clarella/@42.0836,2.3144,15z" target="_blank" rel="noopener noreferrer">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2968.5!2d2.3144!3d42.0836!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDA1JzAxLjAiTiAywrAxOCc1MS44IkU!5e0!3m2!1sca!2ses!4v1"
              width="100%"
              height="400"
              style="border:0; border-radius: 2px;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Location of Mas Clarella"
            ></iframe>
          </a>
        </div>
        <div class="contact-quick" style="margin-top: var(--space-lg);">
          <p>T. <a href="tel:+34683602397">+34 683 60 23 97</a></p>
          <p><a href="mailto:info@clarella.cat">info@clarella.cat</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .page-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .page-hero-title {
    color: var(--color-text-light);
    font-size: var(--text-6xl);
    letter-spacing: 0.1em;
  }

  .events-intro {
    font-size: var(--text-lg);
    line-height: 1.8;
  }

  .events-cta-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    letter-spacing: 0.08em;
    color: var(--color-accent-gold);
  }

  .experiences-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  .experience-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-dark);
    border-radius: 4px;
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .experience-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .experience-header {
    background: var(--color-bg-dark);
    padding: var(--space-lg) var(--space-xl);
    text-align: center;
  }

  .experience-name {
    color: var(--color-text-light);
    font-size: var(--text-3xl);
    letter-spacing: 0.1em;
    margin: 0;
  }

  .experience-body {
    padding: var(--space-xl);
  }

  .experience-features {
    margin-bottom: var(--space-lg);
  }

  .experience-features li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border-dark);
    font-size: var(--text-sm);
    line-height: 1.6;
    position: relative;
    padding-left: var(--space-md);
  }

  .experience-features li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-accent-gold);
    font-weight: bold;
  }

  .experience-pricing {
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .price {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    margin: 0;
    font-size: var(--text-sm);
  }

  .price-value {
    font-weight: 600;
    color: var(--color-text-dark);
    font-size: var(--text-lg);
  }

  .experience-btn {
    display: block;
    text-align: center;
  }

  /* Info Grid */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    text-align: center;
  }

  .info-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-dark);
    margin-bottom: var(--space-sm);
  }

  .info-item p {
    font-size: var(--text-sm);
    margin: 0;
  }

  .info-item a {
    color: var(--color-accent-gold);
  }

  /* Map */
  .map-container {
    border-radius: 4px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .contact-quick a {
    color: var(--color-accent-gold);
  }

  @media (max-width: 768px) {
    .experiences-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .page-hero-title {
      font-size: var(--text-3xl);
    }
  }

  @media (max-width: 480px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
