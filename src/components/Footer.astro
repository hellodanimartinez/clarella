---
import { type Lang, useTranslations, getRouteForLang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="site-footer">
  <div class="footer-inner container--wide">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href={getRouteForLang(lang, '/')} class="footer-logo">
          <img src="/images/logo/Clarella-logo-blanc.webp" alt="Clarella" width="160" height="84" />
        </a>
        <p class="footer-tagline">{t('footer.tagline')}</p>
        <div class="footer-social">
          <a href="https://www.facebook.com/masclarella" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/masclarella" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Contact Column -->
      <div class="footer-contact">
        <h4 class="footer-heading">{t('footer.contact')}</h4>
        <address class="footer-address">
          <p>Mas Clarella</p>
          <p>Ctra. Vidrà km 10</p>
          <p>08584, Barcelona</p>
          <p><a href="tel:+34683602397">+34 683 60 23 97</a></p>
          <p><a href="mailto:info@clarella.cat">info@clarella.cat</a></p>
        </address>
      </div>

      <!-- Legal Column -->
      <div class="footer-legal">
        <h4 class="footer-heading">{t('footer.legal')}</h4>
        <ul class="footer-legal-list">
          <li><a href={getRouteForLang(lang, '/avis-legal')}>{t('footer.legal.notice')}</a></li>
          <li><a href={getRouteForLang(lang, '/politica-de-privacitat')}>{t('footer.legal.privacy')}</a></li>
          <li><a href={getRouteForLang(lang, '/politica-de-cookies')}>{t('footer.legal.cookies')}</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-darker);
    color: rgba(255, 255, 255, 0.7);
    padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-3xl);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-logo img {
    height: 65px;
    width: auto;
    margin-bottom: var(--space-md);
    opacity: 0.9;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    line-height: 1.6;
    white-space: pre-line;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-md);
  }

  .footer-social {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-social a {
    color: rgba(255, 255, 255, 0.5);
    transition: color var(--transition-fast);
  }

  .footer-social a:hover {
    color: var(--color-text-light);
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-light);
    margin-bottom: var(--space-md);
  }

  .footer-address {
    font-style: normal;
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  .footer-address a:hover {
    color: var(--color-text-light);
  }

  .footer-legal-list li {
    margin-bottom: 0.5rem;
  }

  .footer-legal-list a {
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .footer-legal-list a:hover {
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
      text-align: center;
    }

    .footer-social {
      justify-content: center;
    }
  }
</style>
